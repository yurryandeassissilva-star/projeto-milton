    var MAP_BLDS = [
      { lbl: 'HTML', x: -40, z: -20, c: '#0088ff', r: 6 },
      { lbl: 'CSS', x: 40, z: -20, c: '#cc00ff', r: 6 },
      { lbl: 'JS', x: -40, z: 32, c: '#ffcc00', r: 6 },
