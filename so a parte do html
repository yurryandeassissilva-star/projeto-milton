    /* --- HTML TOWER --- */
    function createHtmlTower() {
      var x = -40, z = -20, w = 12, h = 60, d = 12;
      var mat = stdMat(0x001833, 0x002266);

      // Corpo principal
      var bodyGeo = new THREE.BoxGeometry(w, h, d);
      var body = new THREE.Mesh(bodyGeo, mat);
      body.position.set(x, h / 2, z);
      body.castShadow = true;
      scene.add(body);
      var frame = neonEdges(bodyGeo, 0x0055ff);
      frame.position.copy(body.position);
      scene.add(frame);

      // Topo piramidal
      var topGeo = new THREE.ConeGeometry(w * 0.55, 14, 4);
      var top = new THREE.Mesh(topGeo, new THREE.MeshStandardMaterial({ color: 0x001155, emissive: 0x0044ff, emissiveIntensity: 1.2 }));
      top.position.set(x, h + 7, z);
      top.rotation.y = Math.PI / 4;
      scene.add(top);

      // Aneis decorativos
      var animRings = [];
      for (var i = 1; i <= 4; i++) {
        var rGeo = new THREE.TorusGeometry(w * 0.75, 0.18, 8, 32);
        var ring = new THREE.Mesh(rGeo, new THREE.MeshStandardMaterial({ color: 0x0066ff, emissive: 0x0066ff, emissiveIntensity: 1.5 }));
        ring.position.set(x, (h * 0.85) / 4 * i, z);
        ring.rotation.x = Math.PI / 2;
        scene.add(ring);
        animRings.push(ring);
      }

      // Janelas
      var wMat = new THREE.MeshStandardMaterial({ color: 0x001a44, emissive: 0x0044bb, emissiveIntensity: 0.9 });
      for (var r = 0; r < 9; r++) {
        for (var c = 0; c < 3; c++) {
          if (Math.random() < 0.35) continue;
          var win = new THREE.Mesh(new THREE.BoxGeometry((w - 1) / 3 * 0.6, (h - 8) / 9 * 0.55, 0.15), wMat);
          win.position.set(x - w / 2 + (c + 0.5) * (w - 1) / 3 + 0.5, 4 + (r + 0.5) * (h - 8) / 9, z + d / 2 + 0.08);
