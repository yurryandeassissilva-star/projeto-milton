    /* ============================================================
       MOVIMENTO DO JOGADOR
       ============================================================ */
    function checkCollision() {
      var px = camera.position.x, pz = camera.position.z;
      for (var i = 0; i < colliders.length; i++) {
        var c = colliders[i];
        var dx = px - c.x, dz = pz - c.z;
        var r = c.r + 0.5;
        if (dx * dx + dz * dz < r * r) return true;
      }
      return false;
    }

    function updateMovement(delta) {
      if (!gameStarted || hologramOpen) return;
      if (!KEYS.w && !KEYS.s && !KEYS.a && !KEYS.d) return;

      var spd = SPD * delta;
      var sinY = Math.sin(camYaw), cosY = Math.cos(camYaw);
      var dx = 0, dz = 0;

      // Vetor de movimento baseado na direcao da camera (yaw)
      if (KEYS.w) { dx -= sinY; dz -= cosY; }   // Frente
      if (KEYS.s) { dx += sinY; dz += cosY; }   // Tras
      if (KEYS.d) { dx += cosY; dz -= sinY; }   // Direita
      if (KEYS.a) { dx -= cosY; dz += sinY; }   // Esquerda

      // Normaliza para velocidade consistente na diagonal
      var len = Math.sqrt(dx * dx + dz * dz);
      if (len > 0) { dx /= len; dz /= len; }

      var prevX = camera.position.x, prevZ = camera.position.z;
      camera.position.x += dx * spd;
      camera.position.z += dz * spd;
      camera.position.y = P_HEIGHT;

      // Limites da cidade
      camera.position.x = Math.max(-BOUNDS, Math.min(BOUNDS, camera.position.x));
      camera.position.z = Math.max(-BOUNDS, Math.min(BOUNDS, camera.position.z));

      // Rollback se colidiu com edificio
      if (checkCollision()) {
        camera.position.x = prevX;
        camera.position.z = prevZ;
      }
    }

    /* ============================================================
       ANIMACOES DOS EDIFICIOS
       ============================================================ */
    function animateBuildings(t) {
      buildings.forEach(function (b) {
        var a = b.anim;
        if (!a) return;

        // HTML Tower — aneis giram
        if (a.rings) {
          a.rings.forEach(function (ring, i) {
            ring.rotation.z = t * 0.25 * (i % 2 === 0 ? 1 : -1);
          });
        }
        // CSS Lab — paineis pulsam
        if (a.panels) {
          a.panels.forEach(function (p, i) {
            p.material.emissiveIntensity = 0.5 + Math.sin(t * 1.8 + i * 1.2) * 0.4;
          });
          if (a.sphere) a.sphere.material.emissiveIntensity = 1.5 + Math.sin(t * 3) * 0.8;
        }
        // JS Arena — wireframe gira
        if (a.domeWire) a.domeWire.rotation.y = t * 0.25;
        if (a.edge) a.edge.material.emissiveIntensity = 1.5 + Math.sin(t * 3) * 0.8;
        // Bootstrap — barras pulsam
        if (a.bars) {
          a.bars.forEach(function (bar, i) {
            bar.material.emissiveIntensity = 0.8 + Math.sin(t * 2 + i * 0.5) * 0.5;
          });
        }
        // A11Y — disco e cupula pulsam
        if (a.disc) a.disc.material.emissiveIntensity = 0.6 + Math.sin(t * 2) * 0.4;
        if (a.dome) a.dome.material.emissiveIntensity = 0.4 + Math.sin(t * 1.5) * 0.3;
        // Luz base de todos
        if (a.basePt) a.basePt.intensity = 2.5 + Math.sin(t * 1.5) * 0.8;
        // Torres da arena
        if (a.tLights) {
          a.tLights.forEach(function (l, i) { l.intensity = 1 + Math.sin(t * 2 + i * 0.8) * 0.5; });
        }
        // AI Center
        if (a.core) {
          a.core.rotation.y = t * 0.5;
          a.core.scale.setScalar(1 + Math.sin(t * 3) * 0.1);
          a.light.intensity = 3 + Math.sin(t * 3) * 2;
        }
      });

      // Cristal central
      if (centralCrystal) {
        centralCrystal.rotation.y = t * 0.6;
        centralCrystal.rotation.x = Math.sin(t * 0.4) * 0.15;
        centralCrystal.position.y = 16.2 + Math.sin(t * 1.2) * 0.4;
      }
      if (crystalLight) {
        crystalLight.intensity = 4 + Math.sin(t * 2.5) * 2;
      }
    }

    /* ============================================================
       INTERACOES (proximidade + tecla E)
       ============================================================ */
    function updateInteractions() {
      if (hologramOpen) return;

      var px = camera.position.x, pz = camera.position.z;
      var closest = null, bestDist = Infinity;

      buildings.forEach(function (b) {
        var dx = px - b.x, dz = pz - b.z;
        var dist = Math.sqrt(dx * dx + dz * dz);
        if (dist < I_DIST && dist < bestDist) {
          closest = b;
          bestDist = dist;
        }
      });

      if (closest !== nearBuilding) {
        nearBuilding = closest;
        var prompt = document.getElementById('prompt');
        var bname = document.getElementById('p-bname');
        if (nearBuilding) {
          bname.textContent = nearBuilding.name;
          prompt.classList.remove('hidden');
        } else {
          prompt.classList.add('hidden');
        }
      }
    }

