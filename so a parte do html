      { lbl: 'A11Y', x: 0, z: 58, c: '#00ff88', r: 6 },
      { lbl: 'PRJ', x: 0, z: -72, c: '#00ccff', r: 5 },
      { lbl: 'AI', x: 0, z: -35, c: '#bb00ff', r: 6 },
      { lbl: 'FRM', x: -100, z: -20, c: '#aaaaaa', r: 5 },
      { lbl: 'MED', x: 100, z: -20, c: '#aaaaaa', r: 5 },
      { lbl: 'TYP', x: -100, z: 32, c: '#aaaaaa', r: 5 },
      { lbl: 'ANI', x: 100, z: 32, c: '#aaaaaa', r: 5 },
      { lbl: 'DOM', x: -40, z: -80, c: '#aaaaaa', r: 5 },
      { lbl: 'ARR', x: 40, z: -80, c: '#aaaaaa', r: 5 },
      { lbl: 'STO', x: -40, z: 90, c: '#aaaaaa', r: 5 },
