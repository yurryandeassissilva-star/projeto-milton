    ];

    function initUI() {
      mapCtx = document.getElementById('minimap').getContext('2d');
      mapCtx.imageSmoothingEnabled = false;
    }

    function updateHUD(t) {
      var px = camera.position.x, pz = camera.position.z;
      document.getElementById('cx').textContent = px.toFixed(1);
      document.getElementById('cz').textContent = pz.toFixed(1);

      // Nome da area
      var locName = 'PRACA CENTRAL';
      for (var i = 0; i < AREAS.length; i++) {
        var a = AREAS[i];
        var dx = px - a.x, dz = pz - a.z;
        if (dx * dx + dz * dz < a.r * a.r) { locName = a.name; break; }
      }
      document.getElementById('hud-loc').textContent = locName;

      // Minimap
      drawMinimap(px, pz);

      // FPS
      fpsCount++;
      if (t - fpsTimer >= 1) {
        document.getElementById('fps').textContent = fpsCount;
        fpsCount = 0;
        fpsTimer = t;
      }
    }

    function drawMinimap(px, pz) {
      if (!mapCtx) return;
      var ctx = mapCtx, W = 152, H = 152, cx = W / 2, cy = H / 2, sc = 0.42;

      ctx.clearRect(0, 0, W, H);
      ctx.fillStyle = 'rgba(0,3,15,.92)';
      ctx.fillRect(0, 0, W, H);

      // Grade
      ctx.strokeStyle = 'rgba(0,40,100,.2)';
      ctx.lineWidth = 0.5;
      for (var i = 0; i < W; i += 16) {
        ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, H); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(W, i); ctx.stroke();
      }

      // Edificios
      MAP_BLDS.forEach(function (b) {
        var mx = cx + b.x * sc, my = cy + b.z * sc;
        ctx.beginPath(); ctx.arc(mx, my, b.r, 0, Math.PI * 2);
        ctx.fillStyle = b.c; ctx.fill();
        ctx.globalAlpha = 0.25;
        ctx.beginPath(); ctx.arc(mx, my, b.r + 3, 0, Math.PI * 2);
        ctx.strokeStyle = b.c; ctx.lineWidth = 2; ctx.stroke();
        ctx.globalAlpha = 1;
        ctx.fillStyle = 'rgba(255,255,255,.8)'; ctx.font = '7px monospace'; ctx.textAlign = 'center';
        ctx.fillText(b.lbl, mx, my - b.r - 3);
      });

      // Jogador
      var mpx = cx + px * sc, mpy = cy + pz * sc;
      ctx.beginPath(); ctx.arc(mpx, mpy, 6.5, 0, Math.PI * 2);
      ctx.strokeStyle = 'rgba(255,255,255,.3)'; ctx.lineWidth = 2; ctx.stroke();
      ctx.beginPath(); ctx.arc(mpx, mpy, 4, 0, Math.PI * 2);
      ctx.fillStyle = '#fff'; ctx.fill();

      ctx.strokeStyle = 'rgba(0,100,200,.4)'; ctx.lineWidth = 1;
      ctx.strokeRect(0.5, 0.5, W - 1, H - 1);
    }

    /* ============================================================
       HOLOGRAM — abre/fecha painel pedagogico
       [DEV NOTE] Esta função injeta as seções dinamicamente via DOM.
       Modifique `BUILDING_DATA` para alterar o conteúdo gerado aqui.
       ============================================================ */
    function openHologram(content) {
      hologramOpen = true;
      document.getElementById('prompt').classList.add('hidden');

      if (typeof checkMissions !== 'undefined') checkMissions(content.title);

      // Aplica cor tematica via CSS custom property
      var panel = document.getElementById('hologram');
      panel.style.setProperty('--hcol', content.color || '#00f5ff');

      document.getElementById('h-ico').innerHTML = content.icon || '&#11041;';
      document.getElementById('h-title').textContent = content.title || '';
      document.getElementById('h-sub').innerHTML = content.sub || '';
      document.getElementById('h-prog').textContent = (content.sections.length) + ' TÓPICOS';

      // Gera secoes de conteudo
      var html = '';
      content.sections.forEach(function (s, i) {
        html += '<div class="h-sec" style="animation-delay:' + (i * 0.08) + 's">' +
          '<div class="h-sh">' +
          '<code class="h-tag">' + s.tag + '</code>' +
          '<span class="h-lbl">' + s.lbl + '</span>' +
          '</div>' +
          '<p class="h-desc">' + s.desc + '</p>' +
          (s.ex ? '<div class="h-code"><div class="h-chd"><span>exemplo</span><span class="lang">code</span></div><pre><code>' + s.ex + '</code></pre></div>' : '') +
          '</div>';
      });
      document.getElementById('h-content').innerHTML = html;

      panel.classList.remove('hidden');

      // Libera o ponteiro para interagir com o painel
      if (document.exitPointerLock) document.exitPointerLock();

      setTimeout(function () {
        document.getElementById('h-content').querySelector('.h-x') || document.getElementById('h-content').focus();
      }, 100);
    }

    function closeHologram() {
      if (!hologramOpen) return;
      hologramOpen = false;

      var panel = document.getElementById('hologram');
      panel.style.animation = 'hClose .3s ease forwards';
      setTimeout(function () {
        panel.classList.add('hidden');
        panel.style.animation = '';
      }, 300);

      if (nearBuilding) {
        document.getElementById('p-bname').textContent = nearBuilding.name;
        document.getElementById('prompt').classList.remove('hidden');
      }
    }

    /* ============================================================
       PARTICULAS — anima a "chuva de dados"
       ============================================================ */
    function animateParticles() {
      if (!ptMesh) return;
      for (var i = 0; i < ptVelocities.length; i++) {
        ptPositions[i * 3 + 1] -= ptVelocities[i];
        if (ptPositions[i * 3 + 1] < 0) ptPositions[i * 3 + 1] = 80;
      }
      ptMesh.geometry.attributes.position.needsUpdate = true;
    }

    /* ============================================================
       GAME LOOP
       [DEV NOTE] Chamado a ~60FPS pelo browser (requestAnimationFrame).
       Ordem de execução é vital: Movimento -> Colisões -> Animações Internas -> Animações Externas -> HUD -> WebGL Render.
       ============================================================ */
    function animate() {
      requestAnimationFrame(animate);

      // Renderiza a cena de fundo mesmo antes de comecar
      if (!gameStarted) {
        renderer.render(scene, camera);
        return;
      }

      var delta = Math.min(clock.getDelta(), 0.1);
      var time = clock.getElapsedTime();

      updateMovement(delta);
      updateInteractions();
      animateBuildings(time);
      animateParticles();
      updateHUD(time);

      if (typeof updateCitizens !== 'undefined') updateCitizens(delta, time, BOUNDS);
  if (typeof updateDrones !== 'undefined') updateDrones(delta, time);
  if (typeof updateHovercars !== 'undefined') updateHovercars(delta, time, BOUNDS);
      if (typeof updatePanels !== 'undefined') updatePanels(time);

      renderer.render(scene, camera);
    }

    /* ============================================================
       FUNCOES GLOBAIS (chamadas pelos botoes HTML)
       ============================================================ */
    function startGame() {
      document.getElementById('start-screen').classList.add('hidden');
      document.getElementById('hud').classList.remove('hidden');
      gameStarted = true;
      document.getElementById('game-canvas').requestPointerLock();
    }

    function resumeGame() {
      document.getElementById('pause-scr').classList.add('hidden');
      document.getElementById('game-canvas').requestPointerLock();
    }

    /* ============================================================
       INICIALIZAR TUDO
       ============================================================ */
    function init() {
      initRenderer();
      initScene();
      initCamera();
      initInput();
      initBuildings();
      initUI();

      if (typeof initCitizens !== 'undefined') initCitizens(scene);
      if (typeof initDrones !== 'undefined') initDrones(scene);
      if (typeof initMissions !== 'undefined') initMissions();

      animate();
    }

    // Inicia quando o DOM estiver pronto
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  </script>
