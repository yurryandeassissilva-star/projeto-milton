    /* ============================================================
       INPUT (teclado + pointer lock + mouse look)
       ============================================================ */
    var isDragging = false;

    function initInput() {
      // Teclado
      document.addEventListener('keydown', function (e) {
        var k = e.key.toLowerCase();
        if (k === 'w' || e.code === 'ArrowUp') KEYS.w = true;
        if (k === 's' || e.code === 'ArrowDown') KEYS.s = true;
        if (k === 'a' || e.code === 'ArrowLeft') KEYS.a = true;
        if (k === 'd' || e.code === 'ArrowRight') KEYS.d = true;
        // Tecla E — interagir
        if (k === 'e') {
          if (!hologramOpen && nearBuilding) { openHologram(nearBuilding.content); }
          else if (hologramOpen) { closeHologram(); }
        }
        // ESC fecha holograma
        if (e.key === 'Escape' && hologramOpen) { closeHologram(); }
      });
      document.addEventListener('keyup', function (e) {
        var k = e.key.toLowerCase();
        if (k === 'w' || e.code === 'ArrowUp') KEYS.w = false;
        if (k === 's' || e.code === 'ArrowDown') KEYS.s = false;
        if (k === 'a' || e.code === 'ArrowLeft') KEYS.a = false;
        if (k === 'd' || e.code === 'ArrowRight') KEYS.d = false;
      });

      // Pointer Lock — captura o mouse no canvas
      var canvas = document.getElementById('game-canvas');
      canvas.addEventListener('mousedown', function () {
        if (gameStarted && !hologramOpen) {
          isDragging = true;
          if (!isLocked) canvas.requestPointerLock();
        }
      });
      document.addEventListener('mouseup', function () {
        isDragging = false;
      });

      document.addEventListener('pointerlockchange', function () {
        isLocked = !!document.pointerLockElement;
        if (!isLocked && !hologramOpen) {
          document.getElementById('pause-scr').classList.remove('hidden');
        } else {
          document.getElementById('pause-scr').classList.add('hidden');
        }
      });

      // Mouse Look — atualiza yaw e pitch
      document.addEventListener('mousemove', function (e) {
        if (!gameStarted || hologramOpen) return;
        if (!isLocked && !isDragging) return; // Fallback: click and drag if not locked

        var mx = e.movementX || e.mozMovementX || e.webkitMovementX || 0;
        var my = e.movementY || e.mozMovementY || e.webkitMovementY || 0;

        camYaw -= mx * SENS;
        camPitch -= my * SENS;
        camPitch = Math.max(-1.3, Math.min(1.3, camPitch));
        camera.rotation.y = camYaw;   // Rotacao horizontal (esq/dir)
        camera.rotation.x = camPitch; // Rotacao vertical (cima/baixo)
      });

      // Resize
      window.addEventListener('resize', function () {
        camera.aspect = window.innerWidth / window.innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(window.innerWidth, window.innerHeight);
      });
    }

