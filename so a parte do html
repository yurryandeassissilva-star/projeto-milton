<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CIDADE CENTRO UNIVERSITÃRIO PROJEÃÃO FRONT-END 2077 | Jogo Educacional 3D</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap"
    rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html,
    body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #000510;
      font-family: 'Orbitron', monospace;
      color: #c0d4ff;
      cursor: crosshair;
    }

    :root {
      --cyan: #00f5ff;
      --pink: #ff00aa;
      --green: #00ff88;
      --yellow: #ffff00;
      --purple: #cc00ff;
      --hcol: #00f5ff;
    }

    .hidden {
      display: none !important;
    }

    /* CANVAS */
    #game-canvas {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }

    /* START SCREEN */
    #start-screen {
      position: fixed;
      inset: 0;
      z-index: 40;
      display: flex;
      align-items: center;
      justify-content: center;
      background: radial-gradient(ellipse at center, rgba(0, 20, 60, .97) 0%, rgba(0, 5, 20, .99) 70%);
    }

    .scanlines {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 245, 255, .02) 2px, rgba(0, 245, 255, .02) 4px);
    }

    .start-content {
      text-align: center;
      padding: 40px;
      max-width: 680px;
      width: 100%;
      position: relative;
      z-index: 1;
    }

    .logo-city {
      font-size: clamp(10px, 1.5vw, 16px);
      color: var(--cyan);
      letter-spacing: .2em;
      opacity: .8;
      margin-bottom: 4px;
      text-transform: uppercase;
    }

    .logo-main {
      font-size: clamp(36px, 8vw, 72px);
      font-weight: 900;
      background: linear-gradient(135deg, var(--cyan), #0066ff, var(--pink));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 20px rgba(0, 245, 255, .5));
      line-height: 1.1;
    }

    .logo-tag {
      font-size: clamp(10px, 1.3vw, 13px);
      letter-spacing: .4em;
      color: var(--pink);
      margin-top: 6px;
    }

    .neon-div {
      height: 2px;
      width: 60%;
      margin: 24px auto;
      background: linear-gradient(90deg, transparent, var(--cyan), var(--pink), transparent);
      box-shadow: 0 0 8px var(--cyan);
    }

    .start-desc {
      font-size: clamp(12px, 1.8vw, 14px);
      color: #8ab4d4;
      line-height: 1.8;
      margin-bottom: 36px;
    }

    .start-desc strong {
      color: var(--cyan);
      font-family: 'Share Tech Mono', monospace;
    }

    #start-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 16px 48px;
      background: transparent;
      border: 2px solid var(--cyan);
      color: var(--cyan);
      font-family: 'Orbitron', monospace;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: .2em;
      cursor: pointer;
      box-shadow: 0 0 15px rgba(0, 245, 255, .3);
      clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
      transition: all .25s;
    }

    #start-btn:hover {
      background: rgba(0, 245, 255, .1);
      box-shadow: 0 0 30px rgba(0, 245, 255, .5);
      color: #fff;
      transform: translateY(-2px);
    }

    .ctrl-row {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      margin-top: 32px;
    }

    .ctrl {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    .ctrl-k {
      padding: 5px 12px;
      border: 1px solid rgba(0, 245, 255, .3);
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--cyan);
    }

    .ctrl-d {
      font-size: 10px;
      color: #5070a0;
      letter-spacing: .1em;
    }

    /* HUD */
    #hud {
      position: fixed;
      inset: 0;
      z-index: 10;
      pointer-events: none;
    }

    #crosshair {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: rgba(0, 245, 255, .7);
      font-size: 22px;
      line-height: 1;
      text-shadow: 0 0 10px var(--cyan);
      user-select: none;
    }

    #hud-loc {
      position: absolute;
      top: 20px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .4em;
      color: var(--cyan);
      text-shadow: 0 0 10px var(--cyan);
      background: rgba(0, 5, 20, .5);
      padding: 6px 20px;
      border: 1px solid rgba(0, 245, 255, .2);
      clip-path: polygon(6px 0%, 100% 0%, calc(100% - 6px) 100%, 0% 100%);
      white-space: nowrap;
    }

    #hud-coords {
      position: absolute;
      bottom: 20px;
      left: 20px;
      display: flex;
      gap: 16px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: rgba(0, 245, 255, .5);
      background: rgba(0, 5, 20, .5);
      padding: 6px 12px;
      border: 1px solid rgba(0, 245, 255, .15);
    }

    #hud-fps {
      position: absolute;
      top: 20px;
      left: 20px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 10px;
      color: rgba(0, 245, 255, .4);
      background: rgba(0, 5, 20, .4);
      padding: 4px 8px;
      border: 1px solid rgba(0, 245, 255, .1);
    }

    #hud-hint {
      position: absolute;
      bottom: 20px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 11px;
      color: rgba(130, 180, 255, .5);
      white-space: nowrap;
      animation: blink 3s ease infinite;
    }

    /* PROMPT */
    #prompt {
      position: absolute;
      bottom: 80px;
      left: 50%;
      transform: translateX(-50%);
      animation: slideUp .3s ease;
    }

    .p-inner {
      display: flex;
      align-items: center;
      gap: 16px;
      background: rgba(0, 10, 30, .85);
      border: 1px solid var(--cyan);
      padding: 12px 24px;
      box-shadow: 0 0 20px rgba(0, 245, 255, .2);
      clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    }

    .p-key {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--cyan);
      color: var(--cyan);
      font-size: 14px;
      font-weight: 700;
      animation: keyPulse 1.5s ease infinite;
    }

    .p-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .p-act {
      font-size: 11px;
      color: #c0d4ff;
      letter-spacing: .1em;
    }

    .p-name {
      font-size: 13px;
      color: var(--cyan);
      font-weight: 700;
      letter-spacing: .15em;
      text-shadow: 0 0 10px var(--cyan);
    }

    /* MINIMAP */
    #minimap-wrap {
      position: absolute;
      top: 20px;
      right: 20px;
      width: 160px;
      background: rgba(0, 5, 20, .9);
      border: 1px solid rgba(0, 100, 200, .4);
      box-shadow: 0 0 15px rgba(0, 100, 200, .2);
      padding: 4px;
    }

    .map-lbl {
      font-size: 8px;
      letter-spacing: .3em;
      color: rgba(0, 245, 255, .5);
      text-align: center;
      padding: 3px 0;
      border-bottom: 1px solid rgba(0, 100, 200, .3);
      margin-bottom: 3px;
    }

    #minimap {
      display: block;
      width: 152px;
      height: 152px;
    }

    /* HOLOGRAM */
    #hologram {
      position: fixed;
      inset: 0;
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0;
      cursor: default;
    }

    .h-back {
      position: absolute;
      inset: 0;
      background: rgba(0, 5, 20, .78);
      backdrop-filter: blur(5px);
    }

    .h-box {
      position: relative;
      z-index: 1;
      width: 100%;
      height: 100%;
      max-width: none;
      max-height: none;
      display: flex;
      flex-direction: column;
      background: rgba(0, 8, 25, .97);
      border-top: 2px solid var(--hcol);
      border-bottom: 2px solid var(--hcol);
      box-shadow: inset 0 0 50px rgba(0, 245, 255, .05);
      animation: hOpen .35s cubic-bezier(.175, .885, .32, 1.275);
    }

    .h-box::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0, 245, 255, .015) 3px, rgba(0, 245, 255, .015) 4px);
      pointer-events: none;
    }

    .h-head {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 20px 32px;
      border-bottom: 1px solid rgba(0, 245, 255, .1);
      flex-shrink: 0;
    }

    .h-ico {
      width: 56px;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--hcol);
      color: var(--hcol);
      font-size: 22px;
      flex-shrink: 0;
      box-shadow: 0 0 15px var(--hcol);
      animation: iconPulse 2s ease infinite;
    }

    .h-titles {
      flex: 1;
    }

    .h-titles h2 {
      font-size: clamp(16px, 2.5vw, 24px);
      font-weight: 900;
      color: var(--hcol);
      text-shadow: 0 0 15px var(--hcol);
      letter-spacing: .12em;
    }

    .h-titles p {
      font-size: 11px;
      color: #5070a0;
      letter-spacing: .2em;
      margin-top: 4px;
      font-family: 'Share Tech Mono', monospace;
    }

    .h-x {
      width: 36px;
      height: 36px;
      background: transparent;
      border: 1px solid rgba(255, 0, 100, .4);
      color: rgba(255, 0, 100, .7);
      font-size: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: all .15s;
      flex-shrink: 0;
      pointer-events: all;
    }

    .h-x:hover {
      background: rgba(255, 0, 100, .1);
      border-color: #ff0066;
      color: #ff0066;
      box-shadow: 0 0 10px rgba(255, 0, 100, .4);
    }

    .h-div {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--hcol), transparent);
      opacity: .4;
      flex-shrink: 0;
    }

    .h-body {
      overflow-y: auto;
      padding: 20px 32px;
      flex: 1;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 14px;
      align-content: start;
      scrollbar-width: thin;
      scrollbar-color: var(--hcol) rgba(0, 20, 50, .5);
    }

    .h-sec {
      background: rgba(0, 20, 50, .5);
      border: 1px solid rgba(0, 245, 255, .08);
      border-left: 3px solid var(--hcol);
      padding: 14px;
      animation: secIn .35s ease both;
    }

    .h-sec:hover {
      background: rgba(0, 30, 70, .6);
    }

    .h-sh {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 6px;
      flex-wrap: wrap;
    }

    .h-tag {
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      color: var(--hcol);
      text-shadow: 0 0 8px var(--hcol);
    }

    .h-lbl {
      font-size: 10px;
      color: #7090b0;
      letter-spacing: .15em;
      text-transform: uppercase;
    }

    .h-desc {
      font-size: 12px;
      line-height: 1.6;
      color: #90b0d0;
      margin-bottom: 8px;
    }

    .h-code {
      background: rgba(0, 0, 10, .8);
      border: 1px solid rgba(0, 245, 255, .12);
      overflow: hidden;
    }

    .h-chd {
      display: flex;
      justify-content: space-between;
      padding: 3px 10px;
      background: rgba(0, 50, 100, .25);
      border-bottom: 1px solid rgba(0, 245, 255, .08);
    }

    .h-chd span {
      font-family: 'Share Tech Mono', monospace;
      font-size: 9px;
      color: #4060a0;
    }

    .h-chd .lang {
      color: var(--hcol);
      opacity: .7;
    }

    .h-code pre {
      padding: 8px 12px;
      overflow-x: auto;
    }

    .h-code code {
      font-family: 'Share Tech Mono', monospace;
      font-size: 10.5px;
      color: #7dd3fc;
      line-height: 1.6;
      white-space: pre;
    }

    .h-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 32px;
      border-top: 1px solid rgba(0, 245, 255, .08);
      flex-shrink: 0;
    }

    .h-fbrand {
      font-size: 9px;
      color: rgba(0, 245, 255, .3);
      letter-spacing: .2em;
    }

    .h-fprog {
      font-family: 'Share Tech Mono', monospace;
      font-size: 9px;
      color: var(--hcol);
      opacity: .6;
      letter-spacing: .15em;
    }

    /* PAUSE */
    #pause-scr {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 5, 20, .78);
      backdrop-filter: blur(8px);
    }

    .p-box {
      text-align: center;
      padding: 48px;
      background: rgba(0, 10, 30, .95);
      border: 1px solid rgba(0, 245, 255, .3);
      min-width: 320px;
      clip-path: polygon(8px 0%, 100% 0%, calc(100% - 8px) 100%, 0% 100%);
    }

    .p-ico {
      font-size: 48px;
      margin-bottom: 16px;
      display: block;
    }

    .p-ttl {
      font-size: 28px;
      color: var(--cyan);
      text-shadow: 0 0 15px var(--cyan);
      margin-bottom: 8px;
    }

    .p-hint {
      font-size: 11px;
      color: #5070a0;
      margin-bottom: 24px;
      letter-spacing: .1em;
    }

    #resume-btn {
      padding: 12px 40px;
      background: transparent;
      border: 2px solid var(--cyan);
      color: var(--cyan);
      font-family: 'Orbitron', monospace;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .2em;
      cursor: pointer;
      transition: all .25s;
    }

    #resume-btn:hover {
      background: rgba(0, 245, 255, .1);
      box-shadow: 0 0 20px rgba(0, 245, 255, .3);
    }

    /* KEYFRAMES */
    @keyframes blink {

      0%,
      100% {
        opacity: .4
      }

      50% {
        opacity: .9
      }
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translate(-50%, 20px)
      }

      to {
        opacity: 1;
        transform: translate(-50%, 0)
      }
    }

    @keyframes keyPulse {

      0%,
      100% {
        box-shadow: 0 0 5px var(--cyan)
      }

      50% {
        box-shadow: 0 0 20px var(--cyan), 0 0 40px rgba(0, 245, 255, .3);
        border-color: #fff
      }
    }

    @keyframes hOpen {
      from {
        opacity: 0;
        transform: scale(.93) translateY(8px)
      }

      to {
        opacity: 1;
        transform: scale(1) translateY(0)
      }
    }

    @keyframes iconPulse {

      0%,
      100% {
        box-shadow: 0 0 10px var(--hcol)
      }

      50% {
        box-shadow: 0 0 25px var(--hcol), 0 0 50px rgba(0, 245, 255, .15)
      }
    }

    @keyframes secIn {
      from {
        opacity: 0;
        transform: translateX(-10px)
      }

      to {
        opacity: 1;
        transform: translateX(0)
      }
    }

    /* MISSIONS */
    #hud-mission {
      position: absolute;
      top: 60px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 13px;
      font-weight: 700;
      color: #ff00aa;
      text-shadow: 0 0 10px #ff00aa;
      background: rgba(0, 5, 20, .6);
      padding: 8px 24px;
      border: 1px solid rgba(255, 0, 170, .4);
      clip-path: polygon(10px 0%, 100% 0%, calc(100% - 10px) 100%, 0% 100%);
    }

    #mission-alert {
      position: absolute;
      top: 30%;
      left: 50%;
      transform: translate(-50%, -50%);
      font-size: 40px;
      font-weight: 900;
      color: #00ff88;
      text-shadow: 0 0 30px #00ff88;
      z-index: 100;
      opacity: 0;
      pointer-events: none;
    }

    @keyframes alertPulse {
      0% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.5);
      }

      20% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1.1);
      }

      30% {
        transform: translate(-50%, -50%) scale(1);
      }

      80% {
        opacity: 1;
      }

      100% {
        opacity: 0;
      }
    }

    @media(max-width:768px) {

      .h-head,
      .h-body,
      .h-foot {
        padding-left: 14px;
        padding-right: 14px
      }

      .h-body {
        grid-template-columns: 1fr
      }
    }
  </style>
</head>

