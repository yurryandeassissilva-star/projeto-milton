    /* ============================================================
       HELPER: CRIAR SPRITE DE TEXTO (LABEL DOS EDIFICIOS)
       ============================================================ */
    function makeLabel(text, color, x, y, z) {
      y += 12; // Eleva os letreiros para melhor visualizacao
      var cv = document.createElement('canvas');
      cv.width = 512; cv.height = 128;
      var ctx = cv.getContext('2d');
      ctx.clearRect(0, 0, 512, 128);
      ctx.shadowColor = ctx.fillStyle = color;
      ctx.shadowBlur = 20;
      ctx.font = 'bold 32px Orbitron, monospace';
      ctx.textAlign = 'center';
      ctx.fillText(text, 256, 76);
      var sp = new THREE.Sprite(new THREE.SpriteMaterial({
        map: new THREE.CanvasTexture(cv), transparent: true
      }));
      sp.scale.set(22, 5.5, 1);
      sp.position.set(x, y, z);
      scene.add(sp);
      return sp;
    }

    function neonEdges(geo, color) {
      var ln = new THREE.LineSegments(
        new THREE.EdgesGeometry(geo),
        new THREE.LineBasicMaterial({ color: color })
      );
      return ln;
    }

    function stdMat(c, e, ei) {
      return new THREE.MeshStandardMaterial({
        color: c, emissive: e, emissiveIntensity: ei !== undefined ? ei : 0.4,
        roughness: 0.3, metalness: 0.7
      });
    }

    function addPointLight(c, intensity, dist, x, y, z) {
      var l = new THREE.PointLight(c, intensity, dist);
      l.position.set(x, y, z);
      scene.add(l);
      return l;
    }

